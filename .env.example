# StoreScope 환경변수 — 복사 후 .env로 저장
# cp .env.example .env && chmod 600 .env

# ── DB ───────────────────────────────────────────────────────────────────────
# Docker 환경: postgresql://shopify:비밀번호@db/storescope
# 로컬 직접: postgresql://localhost/storescope
DATABASE_URL=postgresql://shopify:CHANGE_ME@db/storescope
POSTGRES_PASSWORD=CHANGE_ME

# ── 관리자 ────────────────────────────────────────────────────────────────────
# openssl rand -hex 32
ADMIN_SECRET=CHANGE_ME_min32chars

# ── Paddle 결제 ───────────────────────────────────────────────────────────────
# paddle.com → Developer → Authentication → API Keys
PADDLE_API_KEY=pdl_live_XXXXX
# paddle.com → Developer → Authentication → Client-side tokens
PADDLE_CLIENT_TOKEN=live_XXXXX
# paddle.com → Catalog → Prices → 각 플랜의 Price ID
PADDLE_STARTER_PRICE_ID=pri_XXXXX
PADDLE_PRO_PRICE_ID=pri_XXXXX
# paddle.com → Notifications → New destination → Webhook → Secret key
PADDLE_WEBHOOK_SECRET=XXXXX
# 로컬 테스트 전용 (production에서는 반드시 false)
PADDLE_WEBHOOK_SKIP_VERIFY=false

# ── Telegram 알림 ─────────────────────────────────────────────────────────────
# 1) @BotFather → /newbot → 토큰 복사
# 2) 봇을 개인 채팅에 추가 → https://api.telegram.org/bot<TOKEN>/getUpdates → chat.id 확인
TELEGRAM_BOT_TOKEN=XXXXX:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID=XXXXXXXXXX

# ── 이메일 SMTP ───────────────────────────────────────────────────────────────
# Gmail 앱 비밀번호 방식 (무료):
#   Google 계정 → 보안 → 2단계 인증 ON → 앱 비밀번호 생성 (16자리)
#   SMTP_HOST=smtp.gmail.com / SMTP_USER=your@gmail.com / SMTP_PASS=앱비밀번호
# SendGrid 무료 (100통/일):
#   SMTP_HOST=smtp.sendgrid.net / SMTP_USER=apikey / SMTP_PASS=SG.XXXXX
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@storescope.com

# ── 배포 URL ──────────────────────────────────────────────────────────────────
APP_URL=https://app.yourdomain.com
ALLOWED_ORIGINS=https://app.yourdomain.com
# Docker 내부 통신: streamlit → fastapi (컨테이너 서비스명 사용)
API_BASE_URL=http://api:8000

# ── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4: analytics.google.com → 관리 → 데이터 스트림 → 측정 ID
GA_MEASUREMENT_ID=G-XXXXXXXXXX
